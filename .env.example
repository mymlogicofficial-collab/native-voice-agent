# Flask Settings
FLASK_APP=myapp
FLASK_ENV=development

# Database Credentials
DATABASE_URL=mysql://user:password@localhost/mydatabase

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Rocket.Chat Settings
ROCKETCHAT_URL=https://chat.example.com
ROCKETCHAT_USER=myuser
ROCKETCHAT_PASSWORD=mypassword

# TTS Engine Parameters
TTS_ENGINE=google
TTS_LANGUAGE=en-US
TTS_VOICE=male

# Server Port Assignments
PORT=5000